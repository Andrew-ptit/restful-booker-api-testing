                  "const res = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Validate response structure\", function () {\r",
                  "    pm.expect(res).to.have.property(\"bookingid\");\r",
                  "    pm.expect(res.booking).to.have.property(\"firstname\");\r",
                  "});\r",
                  "\r",
                  "pm.collectionVariables.set(\"bookingId\", res.bookingid);"
