                  "    pm.expect(res.bookingid).to.be.a(\"number\");",
                  "});",
                  "",
                  "pm.test(\"booking object exists\", function () {",
                  "    pm.expect(res).to.have.property(\"booking\");",
                  "});",
                  "",
                  "pm.test(\"firstname matches request\", function () {",
                  "    pm.expect(res.booking.firstname).to.eql(req.firstname);",
                  "});",
                  "",
                  "pm.test(\"lastname matches request\", function () {",
                  "    pm.expect(res.booking.lastname).to.eql(req.lastname);",
                  "});",
                  "",
                  "pm.test(\"totalprice matches request\", function () {",
                  "    pm.expect(res.booking.totalprice).to.eql(req.totalprice);",
                  "});",
                  "",
                  "pm.test(\"depositpaid matches request\", function () {",
                  "    pm.expect(res.booking.depositpaid).to.eql(req.depositpaid);",
                  "});",
                  "",
                  "pm.test(\"checkin matches request\", function () {",
                  "    pm.expect(res.booking.bookingdates.checkin).to.eql(req.bookingdates.checkin);",
                  "});",
                  "",
                  "pm.test(\"checkout matches request\", function () {",
                  "    pm.expect(res.booking.bookingdates.checkout).to.eql(req.bookingdates.checkout);",
                  "});",
                  "",
                  "pm.test(\"additionalneeds matches request\", function () {",
                  "    pm.expect(res.booking.additionalneeds).to.eql(req.additionalneeds);",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"bookingId\", res.bookingid);",
                  "pm.collectionVariables.set(\"firstname\", req.firstname);",
                  "pm.collectionVariables.set(\"lastname\", req.lastname);",
                  "pm.collectionVariables.set(\"totalprice\", String(req.totalprice));",
                  "pm.collectionVariables.set(\"depositpaid\", String(req.depositpaid));",
                  "pm.collectionVariables.set(\"checkin\", req.bookingdates.checkin);",
                  "pm.collectionVariables.set(\"checkout\", req.bookingdates.checkout);",
                  "pm.collectionVariables.set(\"additionalneeds\", req.additionalneeds);"
